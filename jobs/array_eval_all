#!/bin/bash --login
#SBATCH -p gpuA
#SBATCH -G 1
#SBATCH -c 8
#SBATCH -t 1-0
#SBATCH --mail-type=ALL
#SBATCH --mail-user=theodor.wulff@manchester.ac.uk
#SBATCH --array=0-15

echo "Job is using $SLURM_GPUS GPU(s) with ID(s) $CUDA_VISIBLE_DEVICES and $SLURM_NTASKS CPU core(s)"

export OMP_NUM_THREADS=$SLURM_CPUS_PER_TASK # reduce overloading GPU node
export HF_HOME="$PWD/.hfcache"

module purge
module load libs/cuda

# Print job information
echo "Job started at: $(date)"
echo "Running on node: $(hostname)"
echo "Job ID: $SLURM_JOB_ID"


COLLECTION_RUN_NAMES=(
    "Attribution-Patching-portable-sambar"
    "Attribution-Patching-little-goshawk"
    "Attribution-Patching-thoughtful-hamster"
    "Attribution-Patching-maroon-chihuahua"
    "Attribution-Patching-lime-starling"
    "Attribution-Patching-resourceful-rhino"
    "Attribution-Patching-ivory-yak"
    "Attribution-Patching-observant-whippet"
    "Attribution-Patching-boisterous-frog"
    "Attribution-Patching-lilac-phoenix"
    "Attribution-Patching-warping-hoatzin"
    "Attribution-Patching-enchanted-lobster"
    "Attribution-Patching-meticulous-jellyfish"
    "Attribution-Patching-ochre-cicada"
    "Attribution-Patching-practical-urchin"
)
INDEX=${SLURM_ARRAY_TASK_ID}
echo "Evaluation on with run_name=${COLLECTION_RUN_NAMES[$INDEX]}"

# Run the setup script
source "$PWD/.venv/bin/activate"
python main.py --config-name=eval +activation_reader.run_name=${COLLECTION_RUN_NAMES[$INDEX]}

deactivate

# Print completion message
echo "Job finished at: $(date)"
