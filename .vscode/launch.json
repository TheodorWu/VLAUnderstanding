{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Test Perturbations",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_perturbations",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Test Data",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_data",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Test Model",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_model",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: Test Method",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_method",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }

    ]
}
