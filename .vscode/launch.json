    "version": "0.2.0",
    "configurations": [

        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Test Perturbations",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_perturbations",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Data",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_data",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Model",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_model",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Test Method",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_method",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Activation Writer",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_activation_writer",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Activation Reader",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_activation_reader",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Evaluation",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_evaluation",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Evaluation Activation Patching",
            "type": "debugpy",
            "request": "launch",
            "module": "tests.test_evaluation_activation_patching",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }

    ]
}
